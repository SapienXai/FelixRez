# Supabase (server-side)
SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key" # Never expose to the browser
SUPABASE_ANON_KEY="your_anon_key"

# Supabase (client-side)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key" # Safe for client

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# App config
MANAGEMENT_EMAIL="info@yourdomain.com"

# Web Push notifications
# Generate with: npx web-push generate-vapid-keys
WEB_PUSH_PUBLIC_KEY="your_vapid_public_key"
WEB_PUSH_PRIVATE_KEY="your_vapid_private_key"
WEB_PUSH_SUBJECT="mailto:info@yourdomain.com"
